root = true

[*]
# UTF-8 without BOM — aligned with ExcludeRules: PSUseBOMForUnicodeEncodedFile
charset = utf-8
# Aligned with PSUseConsistentIndentation defaults: Kind = 'space', IndentationSize = 4
indent_style = space
indent_size = 4
# Aligned with PSAvoidTrailingWhitespace (enabled by default)
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf

[*.{ps1,psm1,psd1}]
indent_size = 4
# Aligned with PSAvoidLongLines default: MaximumLineLength = 120
max_line_length = 120

[*.md]
# Markdown trailing spaces can be significant (line breaks)
trim_trailing_whitespace = false
# Prose target — tables are exempt (no wrapping)
max_line_length = 140

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2
